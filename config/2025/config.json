        {
          "title": "Starting Position",
          "description": "The starting position of the robot.",
          "type": "select",
          "required": true,
          "code": "StPo",
          "formResetBehavior": "reset",
          "defaultValue": "",
          "choices": {
            "L": "Left",
            "M": "Middle",
            "R": "Right",
            "X": "Not Present"
          }
        }
      ]
    },
    {
      "name": "During Match",
      "fields": [
        {
          "title": "Moved in Auto?",
          "description": "Check if the robot moved during autonomous.",
          "type": "boolean",
          "required": false,
          "code": "Mved",
          "formResetBehavior": "reset",
          "defaultValue": false
        },
        {
          "title": "Coral L1 Scored",
          "description": "The number of level 1 coral scored.",
          "type": "counter",
          "required": false,
          "code": "CLO",
          "formResetBehavior": "reset",
          "defaultValue": 0,
          "min": 0,
          "step": 1
        },
        {
          "title": "Coral L2 Scored",
          "description": "The number of level 2 coral scored.",
          "type": "counter",
          "required": false,
          "code": "CLT",
          "formResetBehavior": "reset",
          "defaultValue": 0,
          "min": 0,
          "step": 1
        },
        {
          "title": "Coral L3 Scored",
          "description": "The number of level 3 coral scored.",
          "type": "counter",
          "required": false,
          "code": "CLTh",
          "formResetBehavior": "reset",
          "defaultValue": 0,
          "min": 0,
          "step": 1
        },
        {
          "title": "Coral L4 Scored",
          "description": "The number of level 4 coral scored.",
          "type": "counter",
          "required": false,
          "code": "CLF",
          "formResetBehavior": "reset",
          "defaultValue": 0,
          "min": 0,
          "step": 1
        },
        {
          "title": "Barge Algae Scored",
          "description": "The number of Algae scored in the barge directly by the robot.",
          "type": "counter",
          "required": false,
          "code": "BAS",
          "formResetBehavior": "reset",
          "defaultValue": 0,
          "min": 0,
          "step": 1
        },
        {
          "title": "Processor Algae Scored",
          "description": "The number of Algae scored in the processor.",
          "type": "counter",
          "required": false,
          "code": "PAS",
          "formResetBehavior": "reset",
          "defaultValue": 0,
          "min": 0,
          "step": 1
        },
        {
          "title": "Algae Dislodged",
          "description": "The number of Algae dislodged and not immediately scored.",
          "type": "counter",
          "required": false,
          "code": "AlDl",
          "formResetBehavior": "reset",
          "defaultValue": 0,
          "min": 0,
          "step": 1
        }
      ]
    },
    {
      "name": "After Match",
      "fields": [
        {
          "title": "End Game Result",
          "type": "select",
          "required": true,
          "code": "ega",
          "formResetBehavior": "reset",
          "defaultValue": "No",
          "choices": {
            "No": "None",
            "P": "Parked",
            "Sc": "Shallow Climb",
            "ScF": "Shallow Climb Failed",
            "Dc": "Deep Climb",
            "DcF": "Deep Climb Failed"
          }
        },
        {
          "title": "Played defense?",
          "type": "boolean",
          "required": false,
          "code": "DfPl",
          "formResetBehavior": "reset",
          "defaultValue": false
        },
        {
          "title": "Defensive Skill",
          "type": "range",
          "required": false,
          "code": "DfSk",
          "formResetBehavior": "reset",
          "defaultValue": 2,
          "min": 1,
          "max": 3,
          "step": 1
        },
        {
          "title": "Finished match?",
          "description": "Set to false if robots tips over, is disabled, etc.",
          "type": "boolean",
          "required": false,
          "code": "Fin",
          "formResetBehavior": "reset",
          "defaultValue": true
        },
        {
          "title": "Notes",
          "description": "Fouls committed, HP notes, etc.",
          "type": "text",
          "required": false,
          "code": "notes",
          "formResetBehavior": "reset",
          "defaultValue": "",
          "min": 0,
          "max": 300
        },
        {
          "title": "Scouting complete?",
          "description": "Set to false if data is incomplete. Thank you for scouting!",
          "type": "boolean",
          "required": false,
          "code": "Cmplt",
          "formResetBehavior": "reset",
          "defaultValue": true
        }
      ]
    }
  ]
