    "sections": [
        {
            "name": "Prematch",
            "fields": [
                {
                    "title": "Scouter Initials",
                    "description": "Enter the initials of the scouter.",
                    "type": "text",
                    "required": true,
                    "code": "scouter",
                    "formResetBehavior": "preserve",
                    "defaultValue": ""
                },
                {
                    "title": "Match Number",
                    "description": "Select the match number.",
                    "type": "TBA-match-number",
                    "required": true,
                    "code": "matchNumber",
                    "formResetBehavior": "increment",
                    "defaultValue": 1
                },
                {
                    "title": "Team and Robot",
                    "description": "Select the team and robot position you are scouting.",
                    "type": "TBA-team-and-robot",
                    "required": true,
                    "code": "robot",
                    "formResetBehavior": "preserve",
                    "defaultValue": null
                },
                {
                    "title": "Starting Position",
                    "description": "The starting position of the robot.",
                    "type": "select",
                    "required": true,
                    "code": "startPos",
                    "formResetBehavior": "reset",
                    "defaultValue": "",
                    "choices": {
                        "OT": "Outpost Trench",
                        "OB": "Outpost Bump",
                        "H": "Hub",
                        "DB": "Depot Bump",
                        "DT": "Depot Trench"
                    }
                }
            ]
        },
        {
            "name": "Match",
            "fields": [
                {
                    "title": "Climbed (Auto)",
                    "description": "Did the robot climb during autonomous?",
                    "type": "select",
                    "required": false,
                    "code": "autoClimbed",
                    "formResetBehavior": "reset",
                    "defaultValue": "No",
                    "choices": {
                        "No": "No Climb",
                        "Yes": "Climb",
                        "F": "Failed Climb"
                    }
                },
                {
                    "title": "Neutral Zone",
                    "description": "Check if the robot entered the neutral zone during autonomous.",
                    "type": "boolean",
                    "required": false,
                    "code": "autoNZ",
                    "formResetBehavior": "reset",
                    "defaultValue": false
                },
                {
                    "title": "Small deliveries",
                    "description": "The number of times the robot delivered a small amount of fuel.",
                    "type": "counter",
                    "required": false,
                    "code": "smallDeliveries",
                    "formResetBehavior": "reset",
                    "defaultValue": 0,
                    "min": 0,
                    "step": 1
                },
                {
                    "title": "Half hopper deliveries",
                    "description": "The number of times the robot delivered about a half hopper's worth of fuel.",
                    "type": "counter",
                    "required": false,
                    "code": "halfHoppers",
                    "formResetBehavior": "reset",
                    "defaultValue": 0,
                    "min": 0,
                    "step": 1
                },
                {
                    "title": "Full hopper deliveries",
                    "description": "The number of times the robot delivered about a full hopper's worth of fuel.",
                    "type": "counter",
                    "required": false,
                    "code": "fullHoppers",
                    "formResetBehavior": "reset",
                    "defaultValue": 0,
                    "min": 0,
                    "step": 1
                },
                {
                    "title": "Climbed (Endgame)",
                    "description": "The level the robot climbed during endgame.",
                    "type": "select",
                    "required": true,
                    "code": "climbed",
                    "formResetBehavior": "reset",
                    "defaultValue": "No",
                    "choices": {
                        "No": "No Climb",
                        "L1": "Level 1",
                        "L2": "Level 2",
                        "L3": "Level 3",
                        "F": "Failed Climb"
                    }
                },
                {
                    "title": "Problems?",
                    "description": "Did the robot have any problems completing the match?",
                    "type": "boolean",
                    "required": false,
                    "code": "problems",
                    "formResetBehavior": "reset",
                    "defaultValue": false
                }
            ]
        },
        {
            "name": "Postmatch",
            "fields": [
                {
                    "title": "Scoring Accuracy",
                    "description": "Rate the robot's scoring accuracy.",
                    "type": "range",
                    "required": false,
                    "code": "scoringAcc",
                    "formResetBehavior": "reset",
                    "defaultValue": 0,
                    "min": 0,
                    "max": 3,
                    "step": 1
                },
                {
                    "title": "Passing Skill",
                    "description": "Rate the robot's passing skill.",
                    "type": "range",
                    "required": false,
                    "code": "passingSkill",
                    "formResetBehavior": "reset",
                    "defaultValue": 0,
                    "min": 0,
                    "max": 3,
                    "step": 1
                },
                {
                    "title": "Defense Skill",
                    "description": "Rate the robot's defensive skill.",
                    "type": "range",
                    "required": false,
                    "code": "defSkill",
                    "formResetBehavior": "reset",
                    "defaultValue": 0,
                    "min": 0,
                    "max": 3,
                    "step": 1
                },
                {
                    "title": "Comments",
                    "type": "text",
                    "required": false,
                    "code": "co",
                    "formResetBehavior": "reset",
                    "defaultValue": "",
                    "min": 0,
                    "max": 300
                }
            ]
        }
    ]
}